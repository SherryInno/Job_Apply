# ─────────────────────────────────────────────
# Job Search — Adzuna API (FREE, real listings)
# ─────────────────────────────────────────────
# Adzuna aggregates real jobs from LinkedIn, Indeed, Glassdoor, ZipRecruiter, etc.
#
# Get your FREE key in 2 minutes:
#   1. Go to https://developer.adzuna.com/
#   2. Click "Register" and create a free account
#   3. Go to "Dashboard" → "API Access Details"
#   4. Copy your App ID and App Key below
#   Free tier: 250 calls/day, no credit card needed
#
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# ─────────────────────────────────────────────
# Ollama — Local AI (resume enhancement)
# ─────────────────────────────────────────────
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral
