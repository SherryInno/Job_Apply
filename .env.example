# Ollama Configuration (Open Source LLM)

# Set the Ollama API URL (default: http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# Set the model to use (default: mistral)
# Available models: mistral, llama2, neural-chat, orca-mini, etc.
# Install a model: ollama pull mistral
OLLAMA_MODEL=mistral

# Job Search: Using RemoteOK API (completely free, no API key needed!)
# RemoteOK focuses on remote jobs and is free to use with no authentication



