# ─────────────────────────────────────────────
# Groq — AI features (resume enhancement, cover letters)
# ─────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# Adzuna API — OPTIONAL (LinkedIn/Indeed/Glassdoor jobs)
# ─────────────────────────────────────────────
# Without this: jobs come from We Work Remotely, Remotive, The Muse (all free, no key).
# With this: also pulls from LinkedIn, Indeed, Glassdoor, ZipRecruiter + 12 more boards.
#
# Get your FREE key in 2 minutes (no credit card):
#   1. Go to https://developer.adzuna.com/
#   2. Click "Register" → create a free account
#   3. Dashboard → "API Access Details" → copy App ID and App Key
#   Free tier: 250 calls/day
#
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
