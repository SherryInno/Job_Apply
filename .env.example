# Ollama Configuration (Open Source LLM)

# Set the Ollama API URL (default: http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# Set the model to use (default: mistral)
# Available models: mistral, llama2, neural-chat, orca-mini, etc.
# Install a model: ollama pull mistral
OLLAMA_MODEL=mistral

# JSearch API Configuration (for real job listings)

# Get a FREE API key from https://rapidapi.com/laimoon-laimoon/api/jsearch
# 1. Sign up at https://rapidapi.com
# 2. Subscribe to JSsearch API (free tier: 100 requests/month)
# 3. Copy your API key below
JSEARCH_API_KEY=sk_...your_jsearch_api_key_here...


